{
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "lib": ["ES2022"],
        "module": "commonjs",
        "jsx": "react-jsx",
        "target": "ES2022",
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": ".",
        "baseUrl": ".",
        "incremental": true,
        "skipLibCheck": true,
        "strictNullChecks": false,
        "useUnknownInCatchVariables": false,
        "noImplicitAny": false,
        "strictBindCallApply": false,
        "forceConsistentCasingInFileNames": false,
        "noFallthroughCasesInSwitch": false,
        "resolveJsonModule": true,
        "noEmitHelpers": true,
        "importHelpers": true,
        "inlineSources": true,
        "typeRoots": ["./node_modules/@types"],
        "types": ["node", "jest"],
        "tsBuildInfoFile": "./dist/.tsbuildinfo",
        "assumeChangesOnlyAffectDirectDependencies": true,
        "disableSourceOfProjectReferenceRedirect": true,

        "paths": {
            "@libs/*": ["./libs/*"],
            "@apps/*": ["./apps/*/src"],

            "@/shared/domain/enums/*": ["./libs/core/domain/enums/*"],
            "@/shared/infrastructure/repositories/*": ["./libs/core/infrastructure/repositories/model/*"],
            "@/shared/utils/cache/*": ["./libs/core/cache/*"],
            "@/shared/utils/*": ["./libs/common/utils/*"],

            "@/config/*": ["./libs/core/infrastructure/config/*"],

            "@/core/domain/issues/*": ["./libs/issues/domain/*"],
            "@/core/domain/auth/*": ["./libs/identity/domain/auth/*"],
            "@/core/domain/automation/enums/*": ["./libs/automation/domain/automation/enum/*"],
            "@/core/domain/automation/contracts/*": ["./libs/automation/domain/automationExecution/contracts/*"],
            "@/core/domain/automation/entities/*": ["./libs/automation/domain/automationExecution/entities/*"],
            "@/core/domain/automation/*": ["./libs/automation/domain/*"],
            "@/core/domain/organization/*": ["./libs/organization/domain/*", "./libs/organization/domain/organization/*"],
            "@/core/domain/team/*": ["./libs/organization/domain/team/*"],
            "@/core/domain/user/*": ["./libs/identity/domain/user/*"],
            "@/core/domain/parameters/*": ["./libs/organization/domain/parameters/*"],
            "@/core/domain/pullRequests/*": ["./libs/platformData/domain/pullRequests/*"],
            "@/core/domain/codeBase/*": ["./libs/code-review/domain/*"],

            "@/core/infrastructure/adapters/services/codeBase/*": ["./libs/code-review/infrastructure/adapters/services/*"],
            "@/core/infrastructure/adapters/services/issues/*": ["./libs/issues/infrastructure/adapters/service/*"],
            "@/core/infrastructure/adapters/services/context/*": ["./libs/ai-engine/infrastructure/adapters/services/context/*"],
            "@/core/infrastructure/adapters/services/permissions/*": ["./libs/identity/infrastructure/adapters/services/permissions/*"],
            "@/core/infrastructure/adapters/services/parameters.service": ["./libs/organization/infrastructure/adapters/services/parameters.service"],
            "@/core/infrastructure/adapters/services/logger/pino.service": ["./test/__mocks__/pino.service"],
            "@/core/infrastructure/adapters/services/logger/observability.service": ["./libs/core/log/observability.service"],
            "@/core/infrastructure/adapters/services/logger/loggerWrapper.service": ["./libs/core/log/loggerWrapper.service"],
            "@/core/infrastructure/adapters/repositories/typeorm/automationExecution.repository": ["./libs/automation/infrastructure/adapters/repositories/automationExecution.repository"],
            "@/core/infrastructure/adapters/repositories/typeorm/schema/automationExecution.model": ["./libs/automation/infrastructure/adapters/repositories/schemas/automationExecution.model"],
            "@/core/infrastructure/adapters/repositories/typeorm/schema/automation.model": ["./libs/automation/infrastructure/adapters/repositories/schemas/automation.model"],
            "@/core/infrastructure/adapters/repositories/typeorm/schema/teamAutomation.model": ["./libs/automation/infrastructure/adapters/repositories/schemas/teamAutomation.model"],
            "@/core/infrastructure/adapters/repositories/typeorm/schema/organization.model": ["./libs/organization/infrastructure/adapters/repositories/schemas/organization.model"],
            "@/core/infrastructure/adapters/repositories/typeorm/schema/team.model": ["./libs/organization/infrastructure/adapters/repositories/schemas/team.model"],
            "@/core/infrastructure/http/controllers/*": ["./apps/api/src/controllers/*"],
            "@/core/infrastructure/http/dtos/*": ["./apps/api/src/dtos/*", "./libs/ee/codeReviewSettingsLog/dtos/*"],

            "@/core/application/use-cases/organizationParameters/*": ["./libs/organization/application/use-cases/organizationParameters/*"],

            "@/ee/kodyIssuesManagement/*": ["./libs/issues/infrastructure/adapters/*"],
            "@/ee/*": ["./libs/ee/*"],

            "@/*": ["./libs/*"]
        }
    },
    "watchOptions": {
        // Avoid looping in "npm run start:dev"
        "watchFile": "useFsEventsOnParentDirectory"
    },
    "include": ["libs", "apps", "test/**/*.ts", "tsconfig-paths-bootstrap.js"],
    "exclude": [
        "node_modules",
        "dist",
        "ormlogs.log",
        "**/*.map"
    ]
}
