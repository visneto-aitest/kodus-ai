#!/bin/sh
set -e

# Kodus CLI installer
# Installs Kodus CLI if not present, authenticates with team key if provided,
# and delegates bundled skill installation to the CLI.

if [ -t 1 ]; then
  BOLD="\033[1m"
  GREEN="\033[32m"
  YELLOW="\033[33m"
  DARK="\033[90m"
  CYAN="\033[36m"
  RESET="\033[0m"
else
  BOLD=""
  GREEN=""
  YELLOW=""
  DARK=""
  CYAN=""
  RESET=""
fi

print_ascii() {
  printf '%s\n' \
' ‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó' \
' ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ' \
' ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó' \
' ‚Ėą‚Ėą‚ēĒ‚ēź‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ' \
' ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēó‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ' \
' ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ'

  printf "\n"
  printf "  ${DARK}AI-powered code review from your terminal${RESET}\n"
}

print_success() {
  printf "${GREEN}‚úď${RESET} %s\n" "$1"
}

print_info() {
  printf "${YELLOW}‚Üí${RESET} %s\n" "$1"
}

print_error() {
  printf "${BOLD}Error:${RESET} %s\n" "$1" >&2
}

print_dim() {
  printf "${DARK}%s${RESET}\n" "$1"
}

get_npm_bin() {
  if npm bin -g >/dev/null 2>&1; then
    npm bin -g
    return 0
  fi

  npm_prefix=$(npm prefix -g)
  printf '%s\n' "$npm_prefix/bin"
}

resolve_kodus_command() {
  if command -v kodus >/dev/null 2>&1; then
    command -v kodus
    return 0
  fi

  npm_bin=$(get_npm_bin)
  candidate="$npm_bin/kodus"
  if [ -x "$candidate" ]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  return 1
}

TEAM_KEY=""
while [ $# -gt 0 ]; do
  case "$1" in
    --team-key)
      TEAM_KEY="$2"
      shift 2
      ;;
    --team-key=*)
      TEAM_KEY="${1#*=}"
      shift
      ;;
    -h|--help)
      echo "Usage: curl -fsSL <url> | bash -s -- [options]"
      echo ""
      echo "Options:"
      echo "  --team-key <key>  Authenticate with team key after installation"
      echo "  -h, --help        Show this help message"
      exit 0
      ;;
    *)
      print_error "Unknown option: $1"
      echo "Use -h or --help for usage information"
      exit 1
      ;;
  esac
done

print_ascii
printf "\n"

print_info "Checking Kodus CLI installation..."
KODUS_WAS_INSTALLED=0
if command -v kodus >/dev/null 2>&1; then
  KODUS_VERSION=$(kodus --version 2>/dev/null || echo "unknown")
  print_success "Kodus CLI is already installed (${KODUS_VERSION})"
  KODUS_WAS_INSTALLED=1
fi

print_info "Updating Kodus CLI..."
if ! command -v npm >/dev/null 2>&1; then
  print_error "npm is required but not installed"
  print_dim "Please install Node.js from https://nodejs.org"
  exit 1
fi

npm install -g @kodus/cli

KODUS_BIN=$(resolve_kodus_command) || {
  print_error "Unable to find kodus after installation. Open a new terminal and try again."
  exit 1
}
KODUS_VERSION=$($KODUS_BIN --version 2>/dev/null || echo "unknown")
if [ "$KODUS_WAS_INSTALLED" -eq 1 ]; then
  print_success "Kodus CLI updated successfully (${KODUS_VERSION})"
else
  print_success "Kodus CLI installed successfully (${KODUS_VERSION})"
fi

printf "\n"

if [ -n "$TEAM_KEY" ]; then
  print_info "Authenticating with team key..."
  if "$KODUS_BIN" auth team-key --key "$TEAM_KEY"; then
    print_success "Authenticated successfully"
  else
    print_error "Authentication failed"
    exit 1
  fi
  printf "\n"
else
  print_dim "No team key provided. Run later with: kodus auth team-key --key <your-key>"
  printf "\n"
fi

print_info "Installing bundled Kodus skills..."
"$KODUS_BIN" skills install
print_success "Bundled skills installed"
