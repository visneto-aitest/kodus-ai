# syntax=docker/dockerfile:1.7
# Multi-stage production build for kodus-web (Next.js)
# Used for both cloud production and QA builds

# 1) Builder stage: install all deps and build
FROM docker.io/library/node:22.22.0-slim AS builder
WORKDIR /usr/src/app

ARG RELEASE_VERSION=local
ENV RELEASE_VERSION=${RELEASE_VERSION}

# Yarn1's default 30s tarball timeout is too tight for slow paths to
# registry.npmjs.org from the GHA runners — see docker/Dockerfile for the
# full rationale. Same fix applies here.
ENV YARN_HTTP_TIMEOUT=600000

COPY package.json yarn.lock ./

RUN --mount=type=cache,target=/yarn-cache,sharing=locked \
    YARN_CACHE_FOLDER=/yarn-cache \
    yarn install --frozen-lockfile --production=false

COPY . .
RUN yarn build

# 2) Production stage: only the final artifacts
FROM docker.io/library/node:22.22.0-slim AS production

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    rm -f /etc/apt/apt.conf.d/docker-clean \
  && apt-get update \
  && apt-get install -y --no-install-recommends curl

WORKDIR /usr/src/app

ENV NODE_ENV=production
ENV WEB_NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

COPY --from=builder --chown=1000:1000 /usr/src/app/.next/standalone ./
COPY --from=builder --chown=1000:1000 /usr/src/app/.next/static ./.next/static
COPY --from=builder --chown=1000:1000 /usr/src/app/public ./public

USER 1000

EXPOSE 3000

CMD ["node", "server.js"]
